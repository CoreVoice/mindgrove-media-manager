# ---- App ----
PORT=3000
# Public base URL used to build short links (no trailing slash)
BASE_URL=http://localhost:3000
# Secret for signing session cookies. CHANGE THIS in production.
SESSION_SECRET=change-me-to-a-long-random-string
# Key used to encrypt stored storage credentials at rest. Defaults to SESSION_SECRET
# if unset. If you change it, saved Bunny/S3 secrets must be re-entered.
APP_SECRET=

# Seed admin account (created on first run if no users exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345

# Max upload size in MB
MAX_FILE_MB=100
# Max size for a backup export/import .zip (can be much bigger than a single upload)
MAX_BACKUP_MB=1024

# ---- Storage ----
# Initial default driver: "local", "bunny", or "s3". Admins can change this at runtime
# in /admin/settings (persisted in the DB, which overrides this value).
STORAGE_DRIVER=local

# ---- Bunny CDN (only needed when STORAGE_DRIVER=bunny) ----
# Storage zone name
BUNNY_STORAGE_ZONE=
# Storage API password/access key (Storage zone > FTP & API Access > Password)
BUNNY_STORAGE_ACCESS_KEY=
# Storage region hostname. Default/main (Falkenstein): storage.bunnycdn.com
# Others: ny.storage.bunnycdn.com, la.storage.bunnycdn.com, sg.storage.bunnycdn.com, etc.
BUNNY_STORAGE_HOST=storage.bunnycdn.com
# Public pull-zone hostname that serves the storage zone (no protocol)
# e.g. myzone.b-cdn.net  or your custom CDN domain
# REQUIRED for public downloads. If empty, app falls back to proxy mode (streams
# files through the app itself — no CDN, uses app bandwidth).
BUNNY_PULL_ZONE_HOST=
# Prefix folder inside the storage zone so uploads don't collide with other content.
BUNNY_BASE_PATH=mindgrove
# Optional: Bunny API key to purge CDN cache on overwrite (account-level API key)
BUNNY_API_KEY=

# ---- S3-compatible (only needed when STORAGE_DRIVER=s3; can also be set in /admin/settings) ----
# Works with AWS S3, Bunny S3 gateway, Cloudflare R2, Backblaze B2, MinIO, etc.
S3_ENDPOINT=
# AWS: region like us-east-1. R2/others: "auto" is fine.
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public CDN/custom-domain base URL for downloads. Empty = app proxies the bytes.
S3_PUBLIC_BASE_URL=
# Folder prefix inside the bucket.
S3_PREFIX=mindgrove
# Set true for MinIO / providers that need path-style URLs.
S3_FORCE_PATH_STYLE=false
