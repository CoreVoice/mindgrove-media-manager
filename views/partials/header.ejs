<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= typeof title !== 'undefined' ? title : 'Mindgrove Files' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Mulish:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/public/style.css" />
</head>
<body data-role="<%= user ? user.role : '' %>">
  <header class="topbar">
    <a href="/" class="brand"><%- include('logo') %></a>
    <div class="topbar-right">
      <% if (user) { %>
        <div class="notifwrap">
          <button class="bellBtn" id="bellBtn" aria-label="Notifications">🔔<span class="badge hidden" id="notifBadge">0</span></button>
          <div class="notifmenu hidden" id="notifMenu">
            <div class="notifhead">Notifications</div>
            <div id="notifList"></div>
            <div class="muted small" id="notifEmpty" style="padding:.7rem .8rem">No notifications yet.</div>
          </div>
        </div>
      <% } %>
      <button class="navToggle" id="navToggle" aria-label="Menu" aria-expanded="false">☰</button>
    </div>
    <nav id="mainNav">
      <% const p = (typeof page !== 'undefined') ? page : '';
         const settingsPages = ['settings', 'mail', 'audit', 'database', 'backup']; %>
      <a href="/" class="<%= p === 'dashboard' ? 'active' : '' %>">Dashboard</a>
      <% if (user && user.role === 'admin') { %>
        <a href="/admin/approvals" class="<%= p === 'approvals' ? 'active' : '' %>">Approvals<% if (typeof pendingCount !== 'undefined' && pendingCount > 0) { %> <span class="badge"><%= pendingCount %></span><% } %></a>
        <a href="/admin/users" class="<%= p === 'users' ? 'active' : '' %>">Users</a>
        <a href="/admin/taxonomy" class="<%= p === 'taxonomy' ? 'active' : '' %>">Taxonomy</a>
        <details class="navdrop<%= settingsPages.includes(p) ? ' active-parent' : '' %>">
          <summary>Settings</summary>
          <div class="navmenu">
            <a href="/admin/settings" class="<%= p === 'settings' ? 'active' : '' %>">Storage</a>
            <a href="/admin/mail" class="<%= p === 'mail' ? 'active' : '' %>">Mail</a>
            <a href="/admin/audit" class="<%= p === 'audit' ? 'active' : '' %>">Audit Log</a>
            <a href="/admin/database" class="<%= p === 'database' ? 'active' : '' %>">Database</a>
            <a href="/admin/backup" class="<%= p === 'backup' ? 'active' : '' %>">Backup</a>
          </div>
        </details>
      <% } %>
      <span class="who"><%= user ? user.username : '' %><% if (user && user.role === 'admin') { %> · admin<% } %></span>
      <form method="post" action="/logout" class="inline"><button class="linkbtn">Logout</button></form>
    </nav>
  </header>
  <script src="/public/nav.js"></script>
  <% if (user) { %><script src="/public/notifications-ui.js"></script><% } %>