<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Reset password · Mindgrove Files</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Mulish:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/public/style.css" />
</head>
<body class="login-body">
  <main class="login-card">
    <div class="brand"><%- include('partials/logo') %></div>
    <h1><span class="thin">Set a new</span>password</h1>
    <% if (done) { %>
      <p class="sub">Password updated. You can sign in now.</p>
      <p class="sub"><a href="/login">Go to sign in</a></p>
    <% } else if (!valid) { %>
      <div class="alert error">This reset link is invalid or has expired.</div>
      <p class="sub"><a href="/forgot-password">Request a new one</a></p>
    <% } else { %>
      <% if (error) { %><div class="alert error"><%= error %></div><% } %>
      <form method="post" action="/reset-password" class="stack">
        <input type="hidden" name="token" value="<%= token %>" />
        <label>New password
          <input name="password" type="password" autocomplete="new-password" autofocus required minlength="8" />
        </label>
        <button class="btn primary" type="submit">Set password</button>
      </form>
    <% } %>
  </main>
</body>
</html>
