<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Forgot password · Mindgrove Files</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Mulish:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/public/style.css" />
</head>
<body class="login-body">
  <main class="login-card">
    <div class="brand"><%- include('partials/logo') %></div>
    <h1><span class="thin">Reset your</span>password</h1>
    <% if (sent) { %>
      <p class="sub">If that account exists and has an email on file, a reset link has been sent. Check your inbox.</p>
      <p class="sub"><a href="/login">Back to sign in</a></p>
    <% } else { %>
      <p class="sub">Enter your username or email — we'll send a reset link if we find a match.</p>
      <form method="post" action="/forgot-password" class="stack">
        <label>Username or email
          <input name="usernameOrEmail" autofocus required />
        </label>
        <button class="btn primary" type="submit">Send reset link</button>
      </form>
      <p class="sub" style="margin-top:1rem"><a href="/login">Back to sign in</a></p>
    <% } %>
  </main>
</body>
</html>
