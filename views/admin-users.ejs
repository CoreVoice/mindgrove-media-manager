<%- include('partials/header') %>
<main class="container">
  <h1>Users</h1>
  <section class="card">
    <h2>Create user</h2>
    <form id="createUserForm" class="row wrap">
      <input name="username" placeholder="username" required />
      <input name="password" type="password" placeholder="password (min 8)" required />
      <select name="role"><option value="user">user</option><option value="admin">admin</option></select>
      <button class="btn primary" type="submit">Create</button>
      <span id="createMsg" class="msg"></span>
    </form>
  </section>

  <section class="card">
    <table class="grid" id="userTable">
      <thead><tr><th>Username</th><th>Role</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody></tbody>
    </table>
  </section>
</main>
<script src="/public/admin-users.js"></script>
<%- include('partials/footer') %>
