<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Sign in · Mindgrove Files</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Mulish:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/public/style.css" />
</head>
<body class="login-body">
  <main class="login-card">
    <div class="brand"><%- include('partials/logo') %></div>
    <h1><span class="thin">Sign in to</span>Files</h1>
    <p class="sub">Upload assets and manage stable short links.</p>
    <% if (error) { %><div class="alert error"><%= error %></div><% } %>
    <form method="post" action="/login" class="stack">
      <label>Username
        <input name="username" autocomplete="username" autofocus required />
      </label>
      <label>Password
        <input name="password" type="password" autocomplete="current-password" required />
      </label>
      <button class="btn primary" type="submit">Sign in</button>
    </form>
    <p class="sub" style="margin-top:1rem"><a href="/forgot-password">Forgot password?</a></p>
  </main>
</body>
</html>
